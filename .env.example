# Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public API key (Settings > API > Project API keys > anon public)
SUPABASE_KEY=<supabase-anon-key>

# Supabase service role key - JANGAN pernah expose ke client/frontend (Settings > API > Project API keys > service_role)
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Daftar origin yang diizinkan untuk CORS, pisahkan dengan koma (tanpa spasi)
CORS_ORIGINS=http://localhost:3000,http://<ip-or-domain>:3000

# Key untuk enkripsi NIK, gunakan string acak yang kuat (minimal 16 karakter)
NIK_ENCRYPTION_KEY=<random-strong-secret-key>
